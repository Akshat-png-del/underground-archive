{
  "name": "underground-archive",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "audit:archive": "tsx scripts/audit-archive.ts",
    "audit:images": "tsx scripts/audit-images.ts",
    "audit:track-artwork": "tsx scripts/audit-track-artwork.ts",
    "audit:playback": "tsx scripts/audit-playback.ts",
    "audit:playback-full": "tsx scripts/audit-playback-full.ts",
    "stress:playback": "tsx scripts/stress-test-playback.ts",
    "test:playback": "tsx --test tests/playback/*.test.ts",
    "audit:playback-arch": "tsx scripts/audit-playback-architecture.ts",
    "verify:playback": "npm run audit:playback-arch && npm run audit:playback-full && npm run test:playback",
    "validate:playback": "tsx scripts/e2e-playback-validation.ts",
    "debug:playback": "tsx scripts/playback-debug-trace.ts",
    "audit:audible": "tsx scripts/audible-playback-audit.ts",
    "sync:spotify": "tsx scripts/sync/spotify.ts",
    "sync:youtube": "tsx scripts/sync/youtube.ts",
    "sync:musicbrainz": "tsx scripts/sync/musicbrainz.ts",
    "sync:discogs": "tsx scripts/sync/discogs.ts",
    "sync:artist": "tsx scripts/sync/artist.ts",
    "sync:portraits": "tsx scripts/sync/portraits.ts",
    "sync:track-covers": "tsx scripts/sync/track-covers.ts",
    "sync:bundle": "tsx scripts/build-metadata-bundle.ts",
    "sync": "npm run sync:portraits && npm run sync:bundle",
    "expand:catalog": "tsx scripts/expand-catalog.ts",
    "expand:bundle": "tsx scripts/build-expansion-bundle.ts",
    "prebuild": "npm run audit:archive && npm run audit:images",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.1.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "playwright": "^1.61.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
